<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite">
 	
	<groups>
	<run>
		<include name="Smoke"></include>
		<include name="Regression"></include>	
	</run>
	</groups>
	
	<listeners>
	<listener class-name="GenericUtility.ListenersImplimentation"></listener>
	</listeners>

  <test thread-count="5" name="GroupExecution">
    <classes>
      <class name="TestCaseRepo.TestCase_01"/>
      <class name="TestCaseRepo.TC_02"/>
      <class name="TestCaseRepo.TC_03"/>
      <class name="TestCaseRepo.TC_04"/>
      <class name="TestCaseRepo.TC_05"/>
      <class name="TestCaseRepo.TC_06"/>
      <class name="TestCaseRepo.TC_07"/>
      <class name="TestCaseRepo.TC_08"/>
      <class name="TestCaseRepo.TC_09"/>
    </classes>
  </test> <!-- GroupExecution -->
</suite> <!-- Suite -->
